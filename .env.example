# Optional: shared MalfunctionDZ PostgreSQL (users + loft rigs).
# Leave unset if you only need the static marketing site.

# --- VPS (Docker network to platform_py_db) ---
# DB_HOST=platform_py_db
# DB_PORT=5432

# --- Dev (Postgres on host, platform-py docker-compose publishes 5433) ---
# DB_HOST=host.docker.internal
# DB_PORT=5433

DB_NAME=platform
DB_USER=platform
DB_PASS=platform

# Optional full URL (asyncpg: use postgresql:// not +asyncpg)
# DATABASE_URL=postgresql://platform:platform@platform_py_db:5432/platform
